{
  "name": "atlax-minddock",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "pnpm --dir apps/web dev",
    "build": "pnpm build:web",
    "build:web": "pnpm --dir apps/web build",
    "lint": "eslint apps/web packages/domain --ext .ts,.tsx",
    "typecheck": "pnpm --filter @atlax/domain typecheck && pnpm --dir apps/web typecheck",
    "test": "pnpm --filter @atlax/domain test",
    "validate": "pnpm lint && pnpm typecheck && pnpm test"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.28",
    "eslint-plugin-import": "^2.31.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "unrs-resolver"
    ]
  }
}
